datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// --- Better Auth Models ---

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  sessions      Session[]
  accounts      Account[]
  
  keywords      Keyword[]
  groups        MonitoredGroup[]
  posts         Post[]
  logEvents     LogEvent[]
  settings      Settings?

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

// --- Application Models ---

model Keyword {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  keyword   String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  
  @@unique([userId, keyword])
}

model MonitoredGroup {
  id              String   @id @default(cuid())
  facebookGroupId String
  name            String
  iconUrl         String?
  enabled         Boolean  @default(true)
  lastScan        DateTime?
  postsScanned    Int      @default(0)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts           Post[]
  createdAt       DateTime @default(now())

  @@unique([facebookGroupId, userId])
}

model LogEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "INFO", "WARN", "ERROR", "SUCCESS"
  message   String
  metadata  String?  // JSON stringified details
  createdAt DateTime @default(now())
}

model Post {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  facebookPostId String
  groupId        String
  group          MonitoredGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  keyword        String
  content        String
  url            String
  relevant       Boolean
  viewed         Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@unique([userId, facebookPostId])
}

model Settings {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  scanInterval    Int      @default(5)
  activeFrom      String   @default("08:00")
  activeTo        String   @default("20:00")
  monitoringMode  String   @default("default")
  autoScrollPages Int      @default(5)
  groqApiKey      String?  // Encrypted API key
  useGroq         Boolean  @default(true)
  groqSystemPrompt String  @default("You are a lead classifier. Determine if this Facebook post is genuinely looking for the service related to the provided keywords. Respond ONLY with valid JSON: {\"relevant\": true/false}")
}
