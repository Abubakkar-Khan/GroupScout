{
  "manifest_version": 3,
  "name": "GroupScout",
  "version": "1.0.0",
  "description": "Find relevant leads from Facebook Groups",
  "permissions": [
    "storage",
    "alarms",
    "tabs"
  ],
  "host_permissions": [
    "*://*.facebook.com/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "dist/background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.facebook.com/groups/*"],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "GroupScout"
  }
}
